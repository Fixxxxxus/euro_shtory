# Скопируйте в .env.local и подставьте свои значения.

# --- Контакты ---
NEXT_PUBLIC_SITE_NAME=EUROSHTHORY
NEXT_PUBLIC_SITE_TAGLINE=Премиальные системы затемнения для вашего дома
NEXT_PUBLIC_PHONE_TEL=+79637123515
NEXT_PUBLIC_PHONE_DISPLAY=+7 (963) 712-35-15
# Если задано — используется как есть; иначе wa.me собирается из NEXT_PUBLIC_PHONE_TEL
# NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/79000000000
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/euroshtory_ru
NEXT_PUBLIC_TELEGRAM_CHANNEL_URL=https://t.me/euroshtory_ru
NEXT_PUBLIC_ADDRESS=Адрес уточняется
NEXT_PUBLIC_WORK_HOURS=Пн–Сб: 10:00–19:00 · Вс: по договорённости

# --- Hero: фоновое видео ---
# По умолчанию: /videos/hero.mp4 и постер /images/hero-video-poster.jpg (лежат в public/).
# После замены этих файлов перезапустите dev/build — к URL добавится ?hc=<mtime>, чтобы сбросить кэш браузера.
# Переопределение: другой URL или путь
# NEXT_PUBLIC_HERO_VIDEO_URL=https://example.com/hero.mp4
# NEXT_PUBLIC_HERO_VIDEO_POSTER_URL=/images/custom-poster.jpg
# Вертикальное (9:16) видео в широком hero: auto (по размеру файла), true — всегда по центру без обрезки, false — всегда на весь блок (cover)
# NEXT_PUBLIC_HERO_VIDEO_VERTICAL=auto

# --- GitHub Pages (подкаталог репозитория; в CI задаётся в .github/workflows/pages.yml) ---
# Локальная проверка сборки под Pages: npm run build:pages
# NEXT_PUBLIC_BASE_PATH=/euro_shtory

# --- Фото без пересборки логики: см. src/data/realMedia.json и папку public/media/ ---
